JWT_SECRET=lectihub_super_secret_key_change_this_later
PORT=3000

# Optional email integration for schedule confirmations
# Set EMAIL_ENABLED=true to automatically send confirmation emails
EMAIL_ENABLED=false
# log = print to server console (good for local/dev)
# smtp = send through a real SMTP server
EMAIL_MODE=log
EMAIL_FROM=LectiHub <noreply@lectihub.local>

# Optional external calendar live sync (otherwise connected providers use safe local simulation)
GOOGLE_CALENDAR_ENABLED=false
CALENDLY_ENABLED=false

# Integrated meeting platform for online classes (jitsi | google_meet | zoom)
MEETING_PROVIDER=jitsi
JITSI_BASE_URL=https://meet.jit.si
# GOOGLE_MEET_BASE_URL=https://meet.google.com
# ZOOM_MEETING_LINK_TEMPLATE=https://zoom.us/j/{room}
# Allow joining before the scheduled start (handy for demos)
MEETING_ALLOW_EARLY_JOIN=true
MEETING_JOIN_MINUTES_BEFORE=15
MEETING_JOIN_MINUTES_AFTER=15
